{
  "name": "@uigen-dev/core",
  "version": "0.2.1",
  "description": "Framework-agnostic engine for spec-driven frontends",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darula-hpp/uigen.git"
  },
  "homepage": "https://github.com/darula-hpp/uigen#readme",
  "bugs": {
    "url": "https://github.com/darula-hpp/uigen/issues"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.property.test.js",
    "!dist/**/*.property.test.d.ts",
    "!dist/test*.js",
    "!dist/test*.d.ts",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md ./README.md",
    "postpack": "rm -f ./README.md"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "fast-check": "^4.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "frontend-generator",
    "ui-generator",
    "admin-panel",
    "rest-api",
    "react",
    "cli-tool",
    "automation",
    "low-code",
    "no-code",
    "devtools",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
