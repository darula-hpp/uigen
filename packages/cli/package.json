{
  "name": "@uigen-dev/cli",
  "version": "0.1.0",
  "description": "Auto-generate frontends from OpenAPI specs",
  "type": "module",
  "bin": {
    "uigen": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md ./README.md",
    "postpack": "rm -f ./README.md"
  },
  "dependencies": {
    "@uigen-dev/core": "workspace:*",
    "@uigen-dev/react": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["openapi","swagger","frontend-generator","ui-generator","admin-panel","rest-api","react","cli-tool","automation","low-code","no-code","devtools","typescript"],
  "publishConfig": {
    "access": "public"
  }
}
