{
  "name": "@uigen-dev/cli",
  "version": "0.2.5",
  "description": "Auto-generate frontends from OpenAPI specs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darula-hpp/uigen.git"
  },
  "homepage": "https://github.com/darula-hpp/uigen#readme",
  "bugs": {
    "url": "https://github.com/darula-hpp/uigen/issues"
  },
  "type": "module",
  "bin": {
    "uigen": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/renderer/**/*",
    "dist/assets/base-styles.css",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/renderer && cp -r ../react/dist/* dist/renderer/ && mkdir -p dist/assets && cp ../react/src/index.css dist/assets/base-styles.css",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md ./README.md",
    "postpack": "rm -f ./README.md"
  },
  "dependencies": {
    "@uigen-dev/core": "workspace:*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@uigen-dev/react": "workspace:*",
    "fast-check": "^4.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "frontend-generator",
    "ui-generator",
    "admin-panel",
    "rest-api",
    "react",
    "cli-tool",
    "automation",
    "low-code",
    "no-code",
    "devtools",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
