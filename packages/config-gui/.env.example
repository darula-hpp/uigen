# UIGen Config GUI Environment Configuration

# Edition (oss, saas, enterprise)
# Determines which plugins are loaded
VITE_EDITION=oss

# Explicitly enable specific plugins (comma-separated)
# Example: VITE_ENABLED_PLUGINS=auth,analytics,billing
VITE_ENABLED_PLUGINS=

# Explicitly disable specific plugins (comma-separated)
# Example: VITE_DISABLED_PLUGINS=telemetry,tracking
VITE_DISABLED_PLUGINS=

# API Base URL (optional, defaults to relative URLs)
# VITE_API_BASE_URL=http://localhost:3000

# Feature flags (optional)
# VITE_FEATURE_AUTH=true
# VITE_FEATURE_TEAMS=true
# VITE_FEATURE_METRICS=true
