{
  "name": "uigen",
  "version": "0.4.0",
  "private": true,
  "description": "Auto-generate frontends from OpenAPI specs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darula-hpp/uigen.git"
  },
  "homepage": "https://github.com/darula-hpp/uigen#readme",
  "bugs": {
    "url": "https://github.com/darula-hpp/uigen/issues"
  },
  "scripts": {
    "dev": "pnpm --filter @uigen-dev/cli dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:config": "node packages/cli/dist/index.js config examples/apps/fastapi/meeting-minutes/openapi.yaml",
    "test:serve": "node packages/cli/dist/index.js serve examples/apps/fastapi/meeting-minutes/openapi.yaml --proxy-base http://localhost:8000",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
